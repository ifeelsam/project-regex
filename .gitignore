# Dependencies
/node_modules

# Build output
/build
/.svelte-kit
/dist

# Rust / Tauri
/src-tauri/target
/src-tauri/gen

# Bundled sidecar binaries — fetched locally, never committed (see README)
/src-tauri/binaries/*
!/src-tauri/binaries/.gitkeep

# Secrets / env
.env
.env.*
!.env.example

# Editor / OS cruft
.cursor
.DS_Store
*.pem
Thumbs.db
*.log

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Local app data dumps used during debugging
/tmp
*.db
*.db-shm
*.db-wal
